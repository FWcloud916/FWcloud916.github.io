{
  "name": "fwcloud916-blog",
  "version": "1.0.0",
  "description": "A blog built with 11ty and Tailwind CSS",
  "scripts": {
    "build:css": "tailwindcss -i src/assets/css/input.css -o _site/assets/css/styles.css --minify",
    "build:11ty": "eleventy",
    "build": "npm run build:11ty && npm run build:css",
    "watch:css": "tailwindcss -i src/assets/css/input.css -o _site/assets/css/styles.css --watch",
    "watch:11ty": "eleventy --serve",
    "start": "npm-run-all --parallel watch:*",
    "clean": "rm -rf _site"
  },
  "keywords": ["11ty", "blog", "tailwind"],
  "author": "",
  "license": "MIT",
  "overrides": {
    "gray-matter": {
      "js-yaml": "^3.15.0"
    }
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "luxon": "^3.7.2",
    "npm-run-all": "^4.1.5",
    "pinyin-pro": "^3.28.1",
    "prism-themes": "^1.9.0",
    "tailwindcss": "^4.3.2"
  }
}
