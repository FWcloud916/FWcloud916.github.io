<!DOCTYPE html>
<html lang="zh-TW">
<head>
  {% set seoTitle = site.title %}
  {% if title %}{% set seoTitle = title ~ " - " ~ site.title %}{% endif %}
  {% set metaDescription = description or site.description %}
  {% if isArticle and not description %}{% set metaDescription = page.rawInput | seoDescription %}{% endif %}
  {% if not metaDescription %}{% set metaDescription = site.description %}{% endif %}
  {% set canonicalUrl = page.url | absoluteUrl(site.url) %}
  {% set socialImageUrl = (socialImage or site.socialImage) | absoluteUrl(site.url) %}
  {% set robotsContent = "index, follow" %}
  {% if noindex %}{% set robotsContent = "noindex, nofollow" %}{% endif %}
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ seoTitle }}</title>
  <meta name="description" content="{{ metaDescription }}">
  <meta name="robots" content="{{ robotsContent }}">
  {% if site.googleSiteVerification %}
  <meta name="google-site-verification" content="{{ site.googleSiteVerification }}">
  {% endif %}
  {% if site.bingSiteVerification %}
  <meta name="msvalidate.01" content="{{ site.bingSiteVerification }}">
  {% endif %}
  <link rel="canonical" href="{{ canonicalUrl }}">

  <!-- Social sharing -->
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:locale" content="zh_TW">
  <meta property="og:title" content="{{ seoTitle }}">
  <meta property="og:description" content="{{ metaDescription }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:image" content="{{ socialImageUrl }}">
  <meta property="og:image:alt" content="{{ seoTitle }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {% if isArticle %}
  <meta property="og:type" content="article">
  <meta property="article:published_time" content="{{ date | dateIso }}">
  {% if updated %}<meta property="article:modified_time" content="{{ updated | dateIso }}">{% endif %}
  {% for tag in tags | seoTags %}
  <meta property="article:tag" content="{{ tag }}">
  {% endfor %}
  {% else %}
  <meta property="og:type" content="website">
  {% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ seoTitle }}">
  <meta name="twitter:description" content="{{ metaDescription }}">
  <meta name="twitter:image" content="{{ socialImageUrl }}">
  <meta name="twitter:image:alt" content="{{ seoTitle }}">

  <!-- Fonts:Huninn(粉圓體),display=swap 讓 CJK 字型載入期間先以系統字型顯示 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Huninn&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/prism-one-dark.css">
  <link rel="stylesheet" href="/assets/css/styles.css">

  <!-- RSS Feed -->
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="{{ "/feed.xml" | absoluteUrl(site.url) }}">

  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ site.title | safeJson | safe }},
    "url": {{ site.url | safeJson | safe }},
    "description": {{ metaDescription | safeJson | safe }},
    "inLanguage": "zh-TW",
    "author": {
      "@type": "Person",
      "@id": {{ (site.authorUrl ~ "#person") | safeJson | safe }},
      "name": {{ site.author | safeJson | safe }},
      "url": {{ site.authorUrl | safeJson | safe }},
      "sameAs": {{ site.authorSameAs | safeJson | safe }}
    }
  }
  </script>
  {% endif %}
  {% if isArticle %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ title | safeJson | safe }},
    "description": {{ metaDescription | safeJson | safe }},
    "url": {{ canonicalUrl | safeJson | safe }},
    "mainEntityOfPage": {{ canonicalUrl | safeJson | safe }},
    "datePublished": {{ (date | dateIso) | safeJson | safe }},
    "dateModified": {{ ((updated or date) | dateIso) | safeJson | safe }},
    "image": {{ socialImageUrl | safeJson | safe }},
    "keywords": {{ (tags | seoTags) | safeJson | safe }},
    "inLanguage": "zh-TW",
    "author": {
      "@type": "Person",
      "@id": {{ (site.authorUrl ~ "#person") | safeJson | safe }},
      "name": {{ site.author | safeJson | safe }},
      "url": {{ site.authorUrl | safeJson | safe }},
      "sameAs": {{ site.authorSameAs | safeJson | safe }}
    },
    "publisher": {
      "@type": "Person",
      "name": {{ site.author | safeJson | safe }}
    }
  }
  </script>
  {% endif %}
  {% if isProfile %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "name": {{ title | safeJson | safe }},
    "url": {{ canonicalUrl | safeJson | safe }},
    "mainEntity": {
      "@type": "Person",
      "@id": {{ (site.authorUrl ~ "#person") | safeJson | safe }},
      "name": {{ site.author | safeJson | safe }},
      "url": {{ site.authorUrl | safeJson | safe }},
      "description": {{ site.authorDescription | safeJson | safe }},
      "sameAs": {{ site.authorSameAs | safeJson | safe }}
    }
  }
  </script>
  {% endif %}

  <!-- Google Analytics -->
  {% if site.googleAnalyticsId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.googleAnalyticsId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.googleAnalyticsId }}');
  </script>
  {% endif %}
</head>
<body class="bg-gray-50 text-gray-900">
  {% include "components/nav.njk" %}

  <main class="max-w-4xl mx-auto px-4 py-8">
    {{ content | safe }}
  </main>

  <footer class="max-w-4xl mx-auto px-4 py-8 mt-12 border-t border-gray-200">
    <p class="text-center text-gray-600 text-sm">
      &copy; {{ site.currentYear }} {{ site.author }}. All rights reserved.
    </p>
  </footer>
</body>
</html>
