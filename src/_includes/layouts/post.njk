---
layout: layouts/base.njk
---

<article>
  <header class="mb-8">
    <h1 class="text-4xl font-bold mb-4">{{ title }}</h1>
    <div class="flex flex-wrap gap-4 text-sm text-gray-600">
      <span>作者：<a href="{{ site.authorUrl }}" rel="author" class="hover:text-blue-600 transition">{{ site.author }}</a></span>
      <span>發布：<time datetime="{{ date | dateIso }}">{{ date | dateDisplay }}</time></span>
      {% if updated %}<span>更新：<time datetime="{{ updated | dateIso }}">{{ updated | dateDisplay }}</time></span>{% endif %}
      <span>{{ content | readingTime }} 分鐘閱讀</span>
    </div>
    {% if tags %}
    <div class="mt-4 flex flex-wrap gap-2">
      {% for tag in tags %}
        {% if tag != "posts" %}
        <a href="/tags/{{ tag | slug }}/" class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm hover:bg-blue-200 transition">
          #{{ tag }}
        </a>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  </header>

  <div class="prose prose-lg max-w-none">
    {{ content | safe }}
  </div>
</article>
